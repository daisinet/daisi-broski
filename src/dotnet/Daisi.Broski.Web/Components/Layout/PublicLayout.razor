@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@inject Daisi.SDK.Web.Services.AuthService Auth

@* Marketing-surface layout, modelled on daisi-business-crm's
   PublicLayout. Sticky black nav with the DAISI logo-mark +
   the app badge in Anta (here: "BROSKI"), a Bootstrap-grid
   container keeps the brand/nav aligned with the main content
   column. Login / user affordances swap on auth state. *@

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Anta&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="landing-page">
    <nav class="landing-nav">
        <div class="container d-flex align-items-center justify-content-between py-3">
            <a href="/" class="landing-logo">
                <img src="img/daisi-logo-color-white.svg" alt="DAISI" class="logo-img" />
                <span class="logo-badge">BROSKI</span>
            </a>
            <div class="d-flex align-items-center gap-3 landing-nav-links">
                <a href="/docs" class="nav-link-muted">Docs</a>
                @if (_authenticated)
                {
                    <span class="landing-user">@_userName</span>
                    <a href="/admin" class="btn-login">Admin</a>
                    <a href="/account/logout" class="nav-link-muted">Sign out</a>
                }
                else
                {
                    <a href="@_loginUrl" class="btn-login">Login</a>
                }
            </div>
        </div>
    </nav>

    <main>
        @Body
    </main>

    <footer class="landing-footer">
        <div class="container text-center py-4">
            <div class="mb-2 d-flex align-items-center justify-content-center gap-1">
                <img src="img/daisi-logo-color-white.svg" alt="DAISI" style="height: 20px;" />
                <span class="logo-badge" style="font-size: 1rem;">BROSKI</span>
            </div>
            <p class="footer-copyright">
                &copy; @DateTime.UtcNow.Year Distributed AI Systems, Inc. All rights reserved.
            </p>
            <div class="footer-links">
                <a href="https://daisi.net/terms" target="_blank">Terms</a>
                <span class="text-muted mx-2">|</span>
                <a href="https://daisi.net/privacy" target="_blank">Privacy</a>
            </div>
        </div>
    </footer>
</div>

@code {
    private string _loginUrl = "/";
    private bool _authenticated;
    private string _userName = "";

    protected override async Task OnInitializedAsync()
    {
        var appUrl = Daisi.SDK.Models.DaisiStaticSettings.SsoAppUrl;
        var authorityUrl = Daisi.SDK.Models.DaisiStaticSettings.SsoAuthorityUrl;
        if (!string.IsNullOrEmpty(authorityUrl) && !string.IsNullOrEmpty(appUrl))
        {
            var callbackUrl = Uri.EscapeDataString($"{appUrl}/sso/callback");
            var origin = Uri.EscapeDataString(appUrl);
            _loginUrl = $"{authorityUrl}/sso/authorize?returnUrl={callbackUrl}&origin={origin}";
        }
        try { _authenticated = await Auth.IsAuthenticatedAsync(); }
        catch { _authenticated = false; }
        if (_authenticated)
        {
            _userName = HttpContextAccessor.HttpContext?.User
                ?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
        }
    }
}
